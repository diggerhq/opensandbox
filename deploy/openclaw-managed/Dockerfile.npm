# Slim openclaw-managed wrapper built from the npm package, not the
# upstream docker image.
#
# Background: ghcr.io/openclaw/openclaw at 2026.5.2 is 3.25 GB because it
# bakes in every channel + provider extension upstream maintains. The
# npm tarball deliberately excludes channel extensions via package.json's
# "files" field — installing openclaw via npm gives you ~480 MB of core
# gateway + lightweight extensions, vs the docker image's 3+ GB.
#
# This wrapper takes the npm path: a slim Node base + `npm install -g
# openclaw` + our launcher and config baked in. Channel extensions can
# be added at install time via `openclaw plugin install <name>` (the
# upstream-supported lazy install path) — for now we only need
# `telegram`, which is bundled in the npm package's extensions/.
#
# Result: image size ~700 MB (node:22-slim + openclaw + curl), pull
# completes in <10s on a sandbox-rate-limited network.

ARG OPENCLAW_VERSION=2026.5.2
FROM node:22-slim

# curl is used by the HEALTHCHECK and openclaw-launcher's env-file
# sourcing relies on a POSIX shell (already in slim). ca-certificates
# is required for openclaw to call OpenRouter / etc over TLS.
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

ARG OPENCLAW_VERSION
RUN npm install -g openclaw@${OPENCLAW_VERSION} --omit=dev \
 && npm cache clean --force \
 # Channel/provider extensions install their runtime deps (grammy, undici, ...)
 # lazily on first activation. The runtime is the `node` user (uid 1000), but
 # `npm install -g` ran as root, so /usr/lib/node_modules/openclaw is root-owned
 # and lazy installs EACCES out. Hand the tree to node so first-activation
 # installs land cleanly.
 && chown -R node:node /usr/local/lib/node_modules/openclaw

# Match the upstream image's user layout. node:22-slim already provides
# a `node` user at uid 1000, but the home dir layout differs — we create
# /home/node/.openclaw and grant ownership so the bind-mounted host
# config (uid 1000 sandbox user) is read+write at runtime.
RUN mkdir -p /home/node/.openclaw && chown -R node:node /home/node

COPY launcher.sh /usr/local/bin/openclaw-launcher
RUN chmod 0755 /usr/local/bin/openclaw-launcher

COPY --chown=node:node openclaw.json /home/node/.openclaw/openclaw.json

USER node
WORKDIR /home/node

HEALTHCHECK --interval=10s --timeout=3s --start-period=30s --retries=3 \
  CMD curl -sf http://localhost:18789/health || exit 1

EXPOSE 18789
ENTRYPOINT ["/usr/local/bin/openclaw-launcher"]
