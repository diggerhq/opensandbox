# Slim wrapper around the official OpenClaw runtime. Strips features we
# don't use in our managed-agent product (Telegram channel + OpenRouter
# chat completion) so the image fits comfortably under the per-sandbox
# bandwidth profile.
#
# Why a separate Dockerfile (not just additional RUN steps in the main one):
# strip-after-the-fact still inherits all upstream layers, so the
# downloaded layer set stays huge. A multi-stage build with a fresh base
# lets us copy only the trimmed /app and ship a single small layer.
#
# Stripped at build time:
#   - @node-llama-cpp + cuda/vulkan variants (~700 MB) — local LLM
#     inference; we route everything through OpenRouter.
#   - Dev tooling that shouldn't be in prod (typescript native-preview,
#     oxlint, rolldown, esbuild) — ~100 MB.
#   - Channel SDKs we never load: larksuite (feishu), line, mistralai,
#     google genai, etc — ~70 MB.
#   - Image-processing libs (sharp, canvas, pdfjs) — ~110 MB. Re-add via
#     a follow-up if any plugin we actually use needs them.
#   - /app/{docs,src,test,scripts,vendor,ui,apps,skills,changelog} —
#     development artefacts not needed at runtime — ~50 MB.
#   - Channel extensions other than `telegram` — extension folders are
#     6 MB total but their transitive deps in node_modules are bigger.

ARG OPENCLAW_VERSION=2026.2.26
FROM ghcr.io/openclaw/openclaw:${OPENCLAW_VERSION} AS upstream

USER root

# Strip the bloat in-place on the upstream image so multi-stage's COPY
# starts from already-pruned files. Order goes biggest first.
RUN set -e && cd /app \
 && rm -rf node_modules/.pnpm/@node-llama-cpp* \
 && rm -rf node_modules/.pnpm/koffi@* \
 && rm -rf node_modules/.pnpm/node-llama-cpp@* \
 && rm -rf node_modules/.pnpm/@img+sharp-libvips-linux* \
 && rm -rf node_modules/.pnpm/@img+sharp-linux* \
 && rm -rf node_modules/.pnpm/@napi-rs+canvas-linux* \
 && rm -rf node_modules/.pnpm/pdfjs-dist@* \
 && rm -rf node_modules/.pnpm/@larksuiteoapi* \
 && rm -rf node_modules/.pnpm/@line+bot-sdk* \
 && rm -rf node_modules/.pnpm/@mistralai* \
 && rm -rf node_modules/.pnpm/@google+genai* \
 && rm -rf node_modules/.pnpm/@discordjs* \
 && rm -rf node_modules/.pnpm/@whiskeysockets* \
 && rm -rf node_modules/.pnpm/@slack* \
 # @aws-sdk/* is imported eagerly by /app/dist/auth-profiles for the
 # Bedrock LLM provider auth flow — even if we never use Bedrock the
 # module-load fails without it. Keep.
 # && rm -rf node_modules/.pnpm/@aws-sdk* \
 && rm -rf node_modules/.pnpm/@buape* \
 && rm -rf node_modules/.pnpm/@homebridge* \
 && rm -rf node_modules/.pnpm/@typescript+native-preview-linux* \
 && rm -rf node_modules/.pnpm/@oxlint* \
 && rm -rf node_modules/.pnpm/@rolldown* \
 && rm -rf node_modules/.pnpm/@esbuild* \
 && rm -rf node_modules/.pnpm/typescript@* \
 && rm -rf node_modules/.pnpm/tsdown* \
 && rm -rf node_modules/.pnpm/vitest* \
 && rm -rf node_modules/.pnpm/@vitest* \
 && rm -rf node_modules/.pnpm/oxlint@* \
 && rm -rf node_modules/.pnpm/@mariozechner+pi-coding-agent* \
 && rm -rf node_modules/.pnpm/ogg-opus-decoder* \
 && rm -rf docs src test scripts vendor ui apps skills changelog patches \
            git-hooks .github CHANGELOG.md README.md SECURITY.md VISION.md \
            CONTRIBUTING.md AGENTS.md CLAUDE.md \
            Dockerfile* docker-compose.yml docker-setup.sh setup-podman.sh \
            fly.toml fly.private.toml render.yaml zizmor.yml pyproject.toml \
            tsdown.config.ts vitest.*.config.ts vitest.config.ts \
            tsconfig.json tsconfig.plugin-sdk.dts.json appcast.xml \
            openclaw.podman.env \
 && rm -rf extensions/bluebubbles extensions/copilot-proxy \
            extensions/device-pair extensions/discord extensions/feishu \
            extensions/google-gemini-cli-auth extensions/googlechat \
            extensions/imessage extensions/irc extensions/line \
            extensions/lobster extensions/matrix extensions/mattermost \
            extensions/minimax-portal-auth extensions/msteams \
            extensions/nextcloud-talk extensions/nostr \
            extensions/open-prose extensions/phone-control \
            extensions/qwen-portal-auth extensions/signal \
            extensions/synology-chat extensions/talk-voice extensions/tlon \
            extensions/twitch extensions/voice-call extensions/whatsapp \
            extensions/zalo extensions/zalouser

FROM node:22-slim
WORKDIR /app
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

COPY --from=upstream /app /app

# Recreate the `node` user to match upstream image (uid 1000).
RUN if ! id -u node >/dev/null 2>&1; then useradd -u 1000 -m -s /bin/bash node; fi \
 && mkdir -p /home/node/.openclaw \
 && chown -R node:node /home/node /app

# Per-agent env loader (same as the non-slim wrapper).
COPY launcher.sh /usr/local/bin/openclaw-launcher
RUN chmod 0755 /usr/local/bin/openclaw-launcher

# Default openclaw.json with the gateway knobs we need.
COPY --chown=node:node openclaw.json /home/node/.openclaw/openclaw.json

USER node

HEALTHCHECK --interval=10s --timeout=3s --start-period=30s --retries=3 \
  CMD curl -sf http://localhost:18789/health || exit 1

EXPOSE 18789

ENTRYPOINT ["/usr/local/bin/openclaw-launcher"]
