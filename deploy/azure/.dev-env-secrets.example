# Per-location secrets sourced by deploy-azure-dev.sh during `deploy`.
# Copy to .dev-env-secrets-<AZURE_LOCATION> (e.g. .dev-env-secrets-westeurope)
# and fill in. The real file is gitignored.
#
# Fetch the key with:
#   az storage account keys list -n <account> -g <rg> --query '[0].value' -o tsv

CHECKPOINT_STORAGE_ACCOUNT=<storage-account-name>
CHECKPOINT_STORAGE_CONTAINER=<container-name>
CHECKPOINT_STORAGE_KEY=<account-key>
